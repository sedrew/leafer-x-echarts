{
  "name": "leafer-x-echarts",
  "version": "0.2.0",
  "description": "ECharts component for Leafer UI – render interactive charts as SVG inside Leafer canvas (leafer-x plugin)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:visual": "jest tests/visual",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:update-snapshots": "jest --updateSnapshot"
  },
  "peerDependencies": {
    "echarts": ">=5.0.0 <6.0.0",
    "leafer-ui": ">=2.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "echarts": "^5.6.0",
    "jest": "^30.3.0",
    "jest-image-snapshot": "^6.5.2",
    "leafer-ui": "^2.0.8",
    "sharp": "^0.34.5",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "leafer",
    "leafer-ui",
    "echarts",
    "chart",
    "svg",
    "canvas"
  ],
  "author": "Sergei Malygin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sedrew/leafer-echarts"
  },
  "homepage": "https://github.com/sedrew/leafer-echarts#readme",
  "bugs": {
    "url": "https://github.com/sedrew/leafer-echarts/issues"
  },
  "dependencies": {
    "leafer-x-echarts": "^0.2.0"
  }
}
